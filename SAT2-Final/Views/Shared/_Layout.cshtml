<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SAT2 Final Projesi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
            body { background-color: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
            .sidebar { position: fixed; top: 0; bottom: 0; left: 0; z-index: 100; padding: 48px 0 0; box-shadow: inset -1px 0 0 rgba(0, 0, 0, .1); background-color: #2c3e50; color: white; width: 240px; }
            .sidebar .nav-link { font-weight: 500; color: #bdc3c7; padding: 12px 20px; border-radius: 0; }
            .sidebar .nav-link:hover { color: #fff; background-color: #34495e; }
            .sidebar .nav-link.active { color: #3498db; background-color: #1a252f; border-left: 4px solid #3498db; }
            .sidebar .nav-link i { margin-right: 10px; width: 20px; text-align: center; }
            main { margin-left: 240px; padding: 20px; }
            .card { border: none; box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075); border-radius: 12px; }
    </style>
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/15.7.0/nouislider.min.css" />
</head>
<body>
    <nav class="sidebar">
        <div class="position-sticky">
            <div class="px-4 mb-4">
                <h5 class="fw-bold text-white mb-0 d-flex align-items-center">
                    Modül Paneli <i class="fas fa-layer-group ms-2" style="color: #38bdf8;"></i>
                </h5>
                <small class="text-muted" style="font-size: 11px;">Cengiz Alper Erden</small>
            </div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")" asp-action="Index">
                        <i class="fas fa-home"></i> Anasayfa
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "FaceRecognition" ? "active" : "")" asp-action="FaceRecognition">
                        <i class="fas fa-user-circle"></i> Yüz Tanıma
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "QrScanner" ? "active" : "")" asp-action="QrScanner">
                        <i class="fas fa-qrcode"></i> QR
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "MediaRecorder" ? "active" : "")" asp-action="MediaRecorder">
                        <i class="fas fa-microphone"></i> Medya Kaydedici
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "DataTable" ? "active" : "")" asp-action="DataTable">
                        <i class="fas fa-calendar-alt"></i> Etkinlik Takvimi
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "VideoEditor" ? "active" : "")" asp-action="VideoEditor">
                        <i class="fas fa-video"></i> Video Editörü
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <main>
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdnjs.cloudflare.com/ajax/libs/wnumb/1.2.0/wNumb.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/15.7.0/nouislider.min.js"></script>
    <script src="~/js/custom.js" asp-append-version="true"></script>
</body>
</html>