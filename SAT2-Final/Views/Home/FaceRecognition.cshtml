@{
    ViewData["Title"] = "Yüz Tanıma ve Kırpma";
}

<div class="row" id="face-workspace">
    <div class="col-12 text-center mb-4">
        <h2 class="fw-bold">Yapay Zeka Yüz Dedektörü</h2>
        <p class="text-muted">Fotoğraf yükleyin, AI yüzleri tespit edip otomatik olarak kırpsın.</p>
    </div>

    <div class="col-md-6 text-center">
        <div class="upload-box">
            <h5 id="statusText" class="text-warning mb-3">
                <i class="fas fa-spinner fa-spin"></i> Yapay Zeka Modelleri Yükleniyor, Lütfen Bekleyin...
            </h5>
            <input type="file" id="imageUpload" class="form-control" accept="image/*" disabled>
        </div>

        <div class="source-container mt-4">
            <img id="sourceImage" src="" alt="Orijinal" style="display:none; max-width: 100%; border-radius: 8px;">
        </div>
    </div>

    <div class="col-md-6">
        <h5 class="mb-3 border-bottom pb-2">Kırpılan Yüzler</h5>
        <div id="resultArea" class="d-flex flex-wrap gap-3">
            <p class="text-muted small" id="noFaceText">Henüz bir yüz tespit edilmedi.</p>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>