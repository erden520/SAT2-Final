@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="row mb-4">
    <div class="col-12 text-center text-md-start">
        <h2 class="fw-bold text-dark">Sistem Analizi II Final Projesi</h2>
        <p class="text-muted">Hoş geldiniz. Tüm modüllere aşağıdan hızlıca erişebilirsiniz.</p>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-4 col-md-6">
        <div class="card h-100 p-4 text-center shadow-sm border-0 d-flex flex-column">
            <i class="fas fa-user-circle fa-3x text-primary mb-3"></i>
            <h5 class="fw-bold">Yüz Tanıma</h5>
            <p class="small text-muted mb-4">Yapay zeka ile anında yüz tespiti ve otomatik kırpma motoru.</p>
            <a asp-action="FaceRecognition" class="btn btn-outline-primary btn-sm mt-auto w-100">Modüle Git</a>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card h-100 p-4 text-center shadow-sm border-0 d-flex flex-column">
            <i class="fas fa-qrcode fa-3x text-warning mb-3"></i>
            <h5 class="fw-bold">QR & Barkod İstasyonu</h5>
            <p class="small text-muted mb-4">Karekod üretimi ve cihaz kamerası ile canlı barkod tarama.</p>
            <a asp-action="QrScanner" class="btn btn-outline-warning btn-sm mt-auto w-100">Modüle Git</a>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card h-100 p-4 text-center shadow-sm border-0 d-flex flex-column">
            <i class="fas fa-microphone-alt fa-3x text-danger mb-3"></i>
            <h5 class="fw-bold">Medya Kaydedici</h5>
            <p class="small text-muted mb-4">Tarayıcı üzerinden yüksek kaliteli ekran ve ses kaydı altyapısı.</p>
            <a asp-action="MediaRecorder" class="btn btn-outline-danger btn-sm mt-auto w-100">Modüle Git</a>
        </div>
    </div>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-lg-4 col-md-6">
        <div class="card h-100 p-4 text-center shadow-sm border-0 d-flex flex-column">
            <i class="fas fa-calendar-alt fa-3x text-success mb-3"></i>
            <h5 class="fw-bold">Akıllı Ajanda</h5>
            <p class="small text-muted mb-4">Tarayıcı hafızalı, sürükle-bırak destekli gelişmiş etkinlik takvimi.</p>
            <a asp-action="DataTable" class="btn btn-outline-success btn-sm mt-auto w-100">Modüle Git</a>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card h-100 p-4 text-center shadow-sm border-0 d-flex flex-column">
            <i class="fas fa-film fa-3x text-info mb-3"></i>
            <h5 class="fw-bold">Medya Editörü</h5>
            <p class="small text-muted mb-4">WebAssembly (FFmpeg) ile tarayıcı içi video kırpma ve dönüştürme.</p>
            <a asp-action="VideoEditor" class="btn btn-outline-info btn-sm mt-auto w-100">Modüle Git</a>
        </div>
    </div>
</div>