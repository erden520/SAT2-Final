@{
    ViewData["Title"] = "Video & Ses Editörü";
}

<div class="row" id="video-workspace">
    <div class="col-12 text-center mb-4">
        <h2 class="fw-bold">Gelişmiş Medya Editörü</h2>
        <p class="text-muted">Tarayıcı üzerinden videolarınızı kırpın, hızlandırın, yavaşlatın ve formatını değiştirin.</p>
    </div>

    <div class="col-md-5 mb-4">
        <div class="card h-100 p-4 shadow-sm border-0">
            <h5 class="text-primary border-bottom pb-2 mb-3"><i class="fas fa-upload"></i> Medya Yükle ve Ayarla</h5>

            <div class="mb-3">
                <input type="file" id="mediaUpload" class="form-control" accept="video/mp4, video/webm, audio/mp3, audio/wav">
            </div>

            <div class="mb-3">
                <label class="form-label small text-muted">Hız Ayarı (1x Normal)</label>
                <select id="speedSelect" class="form-select">
                    <option value="0.5">0.5x (Yavaş Çekim)</option>
                    <option value="1" selected>1.0x (Normal)</option>
                    <option value="2">2.0x (Hızlı Çekim)</option>
                </select>
            </div>

            <div class="mb-3" id="cropControls" style="display:none;">
                <label class="form-label small text-muted border-bottom pb-1 mb-2 d-block">Kırpma Aralığı</label>

                <div class="d-flex justify-content-between small text-primary fw-bold mb-3">
                    <span>Başlangıç: <span id="startValLabel">0</span> sn</span>
                    <span>Bitiş: <span id="endValLabel">0</span> sn</span>
                </div>

                <div id="dualHandleSlider"></div>
            </div>

            <div class="mb-4">
                <label class="form-label small text-muted">Çıktı Formatı</label>
                <select id="formatSelect" class="form-select">
                    <option value="mp4" selected>MP4 Video</option>
                    <option value="gif">GIF Animasyon</option>
                    <option value="mp3">Sadece Ses (MP3)</option>
                </select>
            </div>

            <button id="processBtn" class="btn btn-primary w-100" disabled>
                <i class="fas fa-cogs"></i> İşlemi Başlat
            </button>

            <div id="loadingArea" class="mt-3 text-center" style="display:none;">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-primary fw-bold" id="statusMessage">Motor Yükleniyor...</p>
            </div>
        </div>
    </div>

    <div class="col-md-7 mb-4">
        <div class="card h-100 p-4 shadow-sm border-0 bg-dark text-white text-center d-flex flex-column justify-content-center align-items-center" id="outputContainer" style="min-height: 300px;">
            <i class="fas fa-film fa-4x text-secondary mb-3" id="placeholderIcon"></i>
            <p class="text-secondary" id="placeholderText">İşlenen medya burada görünecek.</p>

            <video id="outputVideo" controls class="w-100 rounded" style="display:none; max-height: 400px;"></video>
            <img id="outputGif" class="w-100 rounded" style="display:none; max-height: 400px;" />

            <a id="downloadMediaBtn" class="btn btn-success mt-3 w-50" style="display:none;">
                <i class="fas fa-download"></i> Bilgisayara İndir
            </a>
        </div>
    </div>
</div>

<script src="https://unpkg.com/@@ffmpeg/ffmpeg@0.9.8/dist/ffmpeg.min.js"></script>