@{
    ViewData["Title"] = "Etkinlik Takvimi";
}

<div class="row" id="calendar-workspace">
    <div class="col-12 text-center mb-4">
        <h2 class="fw-bold">Akıllı Etkinlik Takvimi</h2>
        <p class="text-muted">Toplantı, sınav veya görevlerinizi ekleyin. Sürükleyip bırakarak günlerini değiştirin.</p>
    </div>

    <div class="col-12">
        <div class="card p-4 shadow-sm border-0">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>